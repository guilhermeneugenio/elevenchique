---
import { Image } from 'astro:assets';
import Layout from '../layouts/Layout.astro';

const imageModules = import.meta.glob<{ default: ImageMetadata }>(
	'../assets/Villa Xique 11/*.jpg',
	{ eager: true }
);
const images = Object.values(imageModules).map(m => m.default);
---

<Layout title="Villa Xique 11 — Elevenchique">
	<main>
		<nav><a href="/">← Back to Villas</a></nav>
		<h1>Villa Xique 11</h1>
		<div class="gallery">
			{images.map((img, i) => (
				<a href={img.src} target="_blank" rel="noopener" class="photo">
					<Image src={img} alt={`Villa Xique 11 ${i + 1}`} widths={[400, 800]} sizes="(max-width: 600px) 100vw, 400px" />
				</a>
			))}
		</div>
	</main>
</Layout>

<style>
	main {
		max-width: 1200px;
		margin: 0 auto;
		padding: 2rem 1.5rem 4rem;
	}

	nav {
		margin-bottom: 1.5rem;
	}

	nav a {
		color: #8b6f47;
		text-decoration: none;
		font-weight: 600;
		font-size: 0.95rem;
	}

	nav a:hover {
		text-decoration: underline;
	}

	h1 {
		font-size: 2.2rem;
		font-weight: 700;
		margin: 0 0 2rem;
		letter-spacing: -0.02em;
	}

	.gallery {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
		gap: 1rem;
	}

	.photo {
		display: block;
		overflow: hidden;
		border-radius: 8px;
		aspect-ratio: 4/3;
		background: #e8e3dc;
	}

	.photo img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		transition: transform 0.3s ease;
	}

	.photo:hover img {
		transform: scale(1.04);
	}
</style>
