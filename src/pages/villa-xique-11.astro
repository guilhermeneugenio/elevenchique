---
import VillaPage from '../components/VillaPage.astro';
import { villaBySlug } from '../data/villas';

const meta = villaBySlug['villa-xique-11'];
const imageModules = import.meta.glob<{ default: ImageMetadata }>(
	'../assets/Villa Xique 11/*.jpg',
	{ eager: true }
);
const images = Object.values(imageModules).map(m => m.default);
---

<VillaPage {...meta} images={images} />