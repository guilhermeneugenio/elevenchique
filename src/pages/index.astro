---
import Layout from '../layouts/Layout.astro';

const villas = [
	{
		name: 'Villa Tucha',
		slug: 'villa-tucha',
		url: 'https://rose-tambourine-abyl.squarespace.com/villa-tucha',
		price: '€260/dia',
		description: 'Em Alvor, esta villa dispõe de acomodações com acesso Wi-Fi gratuito, ar condicionado, 4 quartos, 5 casas de banho, roupa de cama, toalhas, uma televisão com canais por cabo, uma cozinha totalmente equipada e um terraço com vista da montanha.',
		minimum: 'Mínimo 5 noites',
	},
	{
		name: 'Villa Xique 9',
		slug: 'villa-xique-9',
		url: 'https://rose-tambourine-abyl.squarespace.com/villa-xique-9',
		price: '€95/dia',
		description: 'Em Monchique, ideal para desfrutar de atividades como caminhadas e ciclismo, este apartamento com ar condicionado tem 2 quartos, uma sala de estar, uma cozinha totalmente equipada e 2 casas de banho com chuveiro, com todas as comodidades providenciadas.',
		minimum: 'Mínimo 4 noites',
	},
	{
		name: 'Villa Xique 11',
		slug: 'villa-xique-11',
		url: 'https://rose-tambourine-abyl.squarespace.com/villa-xique-11',
		price: '€80/dia',
		description: 'Em Monchique, ideal para desfrutar de atividades como caminhadas e ciclismo, este apartamento tem 1 quarto com uma agradável casa de banho, uma sala com televisão, uma cozinha equipada com frigorífico e máquina de lavar louça e roupa.',
		minimum: 'Mínimo 4 noites',
	},
];
---

<Layout title="Elevenchique — Villas">
	<main>
		<header>
			<h1>Elevenchique</h1>
			<p>Select a villa to explore its gallery</p>
		</header>
		<div class="grid">
			{villas.map(villa => (
				<a href={`/${villa.slug}`} class="card">
					<h2>{villa.name}</h2>
					{villa.price && <p class="price">Desde <strong>{villa.price}</strong></p>}
					<p class="description">{villa.description}</p>
					{villa.minimum && <p class="minimum">{villa.minimum}</p>}
					<span class="cta">Ver galeria →</span>
				</a>
			))}
		</div>
	</main>
</Layout>

<style>
	main {
		max-width: 960px;
		margin: 0 auto;
		padding: 4rem 1.5rem;
	}

	header {
		text-align: center;
		margin-bottom: 3rem;
	}

	header h1 {
		font-size: 2.8rem;
		font-weight: 700;
		letter-spacing: -0.02em;
		margin: 0 0 0.5rem;
	}

	header p {
		font-size: 1.1rem;
		color: #666;
		margin: 0;
	}

	.grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
		gap: 1.5rem;
	}

	.card {
		display: block;
		padding: 2rem;
		border: 1px solid #e0dbd4;
		border-radius: 12px;
		background: #fff;
		text-decoration: none;
		color: inherit;
		transition: box-shadow 0.2s, transform 0.2s;
	}

	.card:hover {
		box-shadow: 0 8px 24px rgba(0,0,0,0.1);
		transform: translateY(-2px);
	}

	.card h2 {
		margin: 0 0 0.5rem;
		font-size: 1.4rem;
	}

	.card p {
		margin: 0 0 0.75rem;
		color: #666;
		font-size: 0.95rem;
	}

	.price {
		font-size: 1rem;
		color: #555;
	}

	.price strong {
		color: #1a1a1a;
	}

	.description {
		line-height: 1.6;
	}

	.minimum {
		display: inline-block;
		font-size: 0.8rem;
		font-weight: 600;
		color: #8b6f47;
		border: 1px solid #c9a97a;
		border-radius: 6px;
		padding: 0.25rem 0.6rem;
		margin: 0 0 1rem;
	}

	.cta {
		font-size: 0.9rem;
		font-weight: 600;
		color: #8b6f47;
	}
</style>
