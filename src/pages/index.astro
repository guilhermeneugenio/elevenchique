---
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets';
import { villas } from '../data/villas';
import villaTuchaImg from '../assets/Villa Tucha/557367909.jpg';
import villaXique9Img from '../assets/Villa Xique 9/494102783.jpg';
import villaXique11Img from '../assets/Villa Xique 11/494097985.jpg';
import villaOlhaoImg from '../assets/olhao/2.jpg';

const coverImages: Record<string, ImageMetadata> = {
	'villa-tucha': villaTuchaImg,
	'villa-xique-9': villaXique9Img,
	'villa-xique-11': villaXique11Img,
	'olhao': villaOlhaoImg,
};
---

<Layout title="Elevenchique — Villas">
	<main>
		<header>
			<h1>Elevenchique</h1>
			<p data-i18n="tagline">Selecione uma villa para explorar a galeria</p>
		</header>
		<div class="grid">
			{villas.map(villa => (
				<a href={`/${villa.slug}`} class="card">
					<Image src={coverImages[villa.slug]} alt={villa.name} class="card-img" widths={[600]} sizes="(max-width: 960px) 100vw, 320px" loading="lazy" />
					<div class="card-body">
						<h2>{villa.name}</h2>
						<p class="price"><span data-i18n="card.from">Desde</span> <strong>{villa.price}</strong></p>
						<p class="description" data-i18n={villa.descKey}>{villa.desc}</p>
					<div class="card-footer">
						<p class="minimum" data-i18n={villa.minKey}>{villa.min}</p>
					</div>
					</div>
				</a>
			))}
		</div>
	</main>
</Layout>

<style>
	main {
		max-width: 1400px;
		margin: 0 auto;
		padding: 4rem 1.5rem;
	}

	header {
		text-align: center;
		margin-bottom: 3rem;
	}

	header h1 {
		font-size: 2.8rem;
		font-weight: 700;
		letter-spacing: -0.02em;
		margin: 0 0 0.5rem;
	}

	header p {
		font-size: 1.1rem;
		color: #666;
		margin: 0;
	}

	.grid {
		display: grid;
		grid-template-columns: repeat(4, 1fr);
		gap: 1.5rem;
	}

	@media (max-width: 900px) {
		.grid {
			grid-template-columns: repeat(2, 1fr);
		}
	}

	@media (max-width: 500px) {
		.grid {
			grid-template-columns: 1fr;
		}
	}

	.card {
		display: flex;
		flex-direction: column;
		border: 1px solid #e0dbd4;
		border-radius: 12px;
		background: #fff;
		text-decoration: none;
		color: inherit;
		overflow: hidden;
		transition: box-shadow 0.2s, transform 0.2s;
	}

	.card-img {
		width: 100%;
		height: 220px;
		object-fit: cover;
		display: block;
	}

	.card-body {
		padding: 1.5rem;
		display: flex;
		flex-direction: column;
		flex: 1;
	}

	.card-footer {
		margin-top: auto;
		padding-top: 1rem;
	}

	.card:hover {
		box-shadow: 0 8px 24px rgba(0,0,0,0.1);
		transform: translateY(-2px);
	}

	.card h2 {
		margin: 0 0 0.5rem;
		font-size: 1.4rem;
	}

	.card p {
		margin: 0 0 0.75rem;
		color: #666;
		font-size: 0.95rem;
	}

	.price {
		font-size: 1rem;
		color: #555;
	}

	.price strong {
		color: #1a1a1a;
	}

	.description {
		line-height: 1.6;
	}

	.minimum {
		display: inline-block;
		font-size: 0.8rem;
		font-weight: 600;
		color: #8b6f47;
		border: 1px solid #c9a97a;
		border-radius: 6px;
		padding: 0.25rem 0.6rem;
		margin: 0;
	}
</style>
